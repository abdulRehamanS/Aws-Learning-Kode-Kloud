      "text": " S3 stands for Super Storage Service. ",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": " S3 stands for Super Storage Service. ",
      "autoResize": true,
