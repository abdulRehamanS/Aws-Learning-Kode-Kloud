      "text": "CloudFormation template CFT ",
      "fontSize": 28,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CloudFormation template CFT ",
      "autoResize": true,
