    {
      "id": "ToBYmH2ljuLJJY-w9Y0Qk",
      "type": "text",
      "x": 1078.87109375,
      "y": 2340.9609375,
      "width": 247.13245315104723,
      "height": 35,
      "angle": 0,
      "strokeColor": "#e03131",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
